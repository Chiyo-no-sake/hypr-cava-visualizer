#!/bin/sh
# Wrapper that sets LD_PRELOAD for gtk4-layer-shell and launches the visualizer.
# Installed by `make install` alongside the Python script.

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"

# Find a Python 3 interpreter that has the required GTK/Cairo system packages.
# Version managers (asdf, pyenv) often shadow /usr/bin/python3 with an interpreter
# that cannot see system site-packages, so we prefer the system python.
find_python() {
    for py in /usr/bin/python3 python3; do
        if command -v "$py" >/dev/null 2>&1 && \
           "$py" -c "import gi, cairo" 2>/dev/null; then
            echo "$py"
            return
        fi
    done
    echo "python3"
}

PYTHON="$(find_python)"

# Find libgtk4-layer-shell
find_layer_shell() {
    # Check if already loadable without preload
    if "$PYTHON" -c "import gi; gi.require_version('Gtk4LayerShell', '1.0')" 2>/dev/null; then
        return 0
    fi

    # Search common paths
    for path in \
        /usr/lib64/libgtk4-layer-shell.so.0 \
        /usr/lib/libgtk4-layer-shell.so.0 \
        /usr/lib/x86_64-linux-gnu/libgtk4-layer-shell.so.0 \
        /usr/lib/aarch64-linux-gnu/libgtk4-layer-shell.so.0 \
        /usr/local/lib64/libgtk4-layer-shell.so.0 \
        /usr/local/lib/libgtk4-layer-shell.so.0; do
        if [ -f "$path" ]; then
            echo "$path"
            return 0
        fi
    done

    # Try ldconfig
    ldconfig -p 2>/dev/null | grep -o '/[^ ]*libgtk4-layer-shell.so.0' | head -1
}

if [ -z "$LD_PRELOAD" ] || ! echo "$LD_PRELOAD" | grep -q "libgtk4-layer-shell"; then
    LIB="$(find_layer_shell)"
    if [ -n "$LIB" ]; then
        export LD_PRELOAD="${LD_PRELOAD:+$LD_PRELOAD:}$LIB"
    fi
fi

exec "$PYTHON" "$SCRIPT_DIR/hypr-cava-visualizer.py" "$@"
